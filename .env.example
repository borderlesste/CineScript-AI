# AI_GATEWAY_API_KEY: Required for Vercel AI Gateway (Gemini).
# Users configure this via the Secrets panel in the AI Studio UI.
AI_GATEWAY_API_KEY="MY_AI_GATEWAY_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# HEYGEN_API_KEY: Required for HeyGen AI video generation.
HEYGEN_API_KEY=

# ELEVENLABS_API_KEY: Required for ElevenLabs premium TTS.
ELEVENLABS_API_KEY=sk_1020971239e6320835f024fa57a2133c8d43c9f254f0e556

# YOUTUBE_API_KEY: Required for YouTube Embedded Player and Data API.
